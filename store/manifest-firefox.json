{
  "manifest_version": 2,
  "name": "defluffer",
  "version": "1.2.0",
  "description": "Trims long, AI-fluffed LinkedIn posts down to one honest line as you scroll. 'John graduated from X.' Done.",
  "permissions": [
    "storage",
    "https://www.linkedin.com/*",
    "https://linkedin-defluffer.defluffer.workers.dev/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "defluffer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "defluffer@itayzit.github.io",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": [
          "websiteContent"
        ]
      }
    }
  }
}
